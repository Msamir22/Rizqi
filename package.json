{
  "name": "rizqi-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Rizqi - The Invisible Money Tracker for Egypt",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install && npm run expo-install -w @rizqi/mobile",
    "api:dev": "npm run dev -w @rizqi/api",
    "api:build": "npm run build -w @rizqi/api",
    "mobile": "npm run start -w @rizqi/mobile",
    "mobile:ios": "npm run ios -w @rizqi/mobile",
    "mobile:android": "npm run android -w @rizqi/mobile",
    "mobile:android:release": "npm run android:release -w @rizqi/mobile",
    "mobile:android-local-build": "npm run android-local-build -w @rizqi/mobile",
    "mobile-prebuild": "npm run prebuild -w @rizqi/mobile",
    "mobile:doctor": "npm run doctor -w @rizqi/mobile",
    "mobile:install-check": "npm run install-check -w @rizqi/mobile",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "android": "expo run:android",
    "start:android": "npm run start -w @rizqi/mobile",
    "ios": "expo run:ios",
    "db:types": "supabase gen types typescript --project-id yulbcndyssdjicbpmlrk > packages/db/src/supabase-types.ts",
    "db:format-types": "npx prettier --write packages/db/src/supabase-types.ts",
    "db:transform": "node scripts/transform-schema.js",
    "db:sync": "npm run db:types && npm run db:format-types && npm run db:transform",
    "db:watermelon-migrate": "node scripts/sql-to-watermelon-migration.js",
    "db:migrate": "npm run db:push -- --include-all && npm run db:sync-local",
    "db:sync-local": "npm run db:watermelon-migrate -- --latest && npm run db:sync",
    "db:pull": "supabase db pull",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:migrations": "supabase migration list",
    "fn:deploy:rates": "supabase functions deploy fetch-metal-rates --project-ref yulbcndyssdjicbpmlrk",
    "fn:deploy:parse-sms": "supabase functions deploy parse-sms --project-ref yulbcndyssdjicbpmlrk",
    "fn:deploy:parse-voice": "supabase functions deploy parse-voice --project-ref yulbcndyssdjicbpmlrk",
    "e2e": "maestro test apps/mobile/e2e/maestro/",
    "test": "npm test -w @rizqi/mobile",
    "prepare": "node -e \"if (process.env.CI !== 'true') { process.exit(1) }\" || husky",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@nozbe/watermelondb": "^0.28.0"
  },
  "devDependencies": {
    "nx": "22.3.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.5.2"
  }
}
