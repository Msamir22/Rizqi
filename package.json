{
  "name": "astik-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Astik - The Invisible Money Tracker for Egypt",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install && npm run expo-install -w @astik/mobile",
    "api:dev": "npm run dev -w @astik/api",
    "api:build": "npm run build -w @astik/api",
    "mobile": "npm run start -w @astik/mobile",
    "mobile:ios": "npm run ios -w @astik/mobile",
    "mobile:android": "npm run android -w @astik/mobile",
    "mobile:android-local-build": "npm run android-local-build -w @astik/mobile",
    "mobile-prebuild": "npm run prebuild -w @astik/mobile",
    "mobile:doctor": "npm run doctor -w @astik/mobile",
    "mobile:install-check": "npm run install-check -w @astik/mobile",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "android": "expo run:android",
    "start:android": "npm run start -w @astik/mobile",
    "ios": "expo run:ios",
    "db:types": "npx supabase gen types typescript --project-id yulbcndyssdjicbpmlrk > packages/db/src/supabase-types.ts",
    "db:transform": "node scripts/transform-schema.js",
    "db:sync": "npm run db:types && npm run db:transform",
    "db:pull": "npx supabase db pull",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:migrations": "npx supabase migration list"
  },
  "dependencies": {
    "@nozbe/watermelondb": "^0.28.0"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "nx": "22.3.3"
  }
}
