{
  "expo": {
    "name": "Rizqi",
    "slug": "rizqi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "rizqi",
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "supportsRTL": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rizqi.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Rizqi needs speech recognition to convert your voice to transactions",
        "NSMicrophoneUsageDescription": "Rizqi needs microphone access for voice input"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.rizqi.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-speech-recognition",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F172A",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#0F172A"
        }
      ],
      "./plugins/withSmsBroadcastReceiver",
      [
        "@sentry/react-native",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "mohamed-samir-de"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
