{
  "name": "@astik/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android-local-build": "npm run prebuild && npx expo run:android --device",
    "prebuild": "npx expo prebuild",
    "eas-android-dev": "npx expo eas-build:android --profile development",
    "eas-android-prod": "npx expo eas-build:android --profile production"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "@nozbe/watermelondb"
        ]
      }
    },
    "install": {
      "exclude": [
        "@nozbe/watermelondb"
      ]
    }
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@nozbe/watermelondb": "^0.27.1",
    "@react-navigation/native": "^7.0.14",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.0",
    "expo-speech-recognition": "^3.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.9",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-css-interop": "^0.1.22",
    "react-native-reanimated": "~3.16.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.4.0"
  }
}
