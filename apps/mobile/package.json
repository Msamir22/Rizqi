{
  "name": "@rizqi/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "android:release": "cross-env EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo run:android --variant release",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android-local-build": "npm run prebuild && npx expo run:android --device",
    "prebuild": "npx expo prebuild",
    "eas-android-dev": "npx expo eas-build:android --profile development",
    "eas-android-prod": "npx expo eas-build:android --profile production",
    "doctor": "npx expo-doctor",
    "install-check": "npx expo install --check",
    "expo-install": "npx expo install",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "i18n:check": "tsx scripts/check-i18n-coverage.ts",
    "i18n:update-baseline": "tsx scripts/check-i18n-coverage.ts --update-baseline"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/noto-sans-arabic": "^0.4.3",
    "@expo-google-fonts/readex-pro": "^0.4.1",
    "@expo/vector-icons": "~14.0.4",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.0.14",
    "@sentry/react-native": "~6.10.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.90.17",
    "expo": "~52.0.48",
    "expo-asset": "~11.0.5",
    "expo-audio": "~0.3.5",
    "expo-auth-session": "~6.0.3",
    "expo-blur": "~14.0.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-localization": "~16.0.1",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-speech-recognition": "^3.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.9",
    "expo-updates": "~0.26.19",
    "expo-web-browser": "~14.0.2",
    "i18next": "^26.0.3",
    "nativewind": "4.2.3",
    "react": "18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.2",
    "react-native": "0.76.9",
    "react-native-css-interop": "0.2.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-sms-android": "^2.1.0",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "~3.16.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
