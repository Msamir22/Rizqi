# Environment variables for API app
# Copy this to .env.local and fill in your actual values

# Supabase
EXPRESS_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPRESS_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
EXPRESS_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# metals.dev API
# Get your free API key at: https://metals.dev
METALS_DEV_API_KEY=your_metals_dev_api_key_here

# Cron job secret
# Generate a random string: openssl rand -base64 32
CRON_SECRET=your_random_secret_string_here

# Server port (optional, defaults to 3001)
PORT=3001

# Node environment
NODE_ENV=development
